# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control - it contains secrets!
#
# Configuration Priority (highest to lowest):
# 1. Environment variables
# 2. .env / .env.local files
# 3. config.toml
# 4. Code defaults
# =============================================================================

# =============================================================================
# Application Settings
# =============================================================================
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# JWT signing secret (generate with: openssl rand -hex 32)
API_SECRET_KEY=your-256-bit-secret-key-here

# Admin login identifier (default: admin)
ADMIN_IDENTIFIER=admin

# Bcrypt hashed admin password (generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'password', bcrypt.gensalt()).decode())")
# In Dokploy/Compose env files, escape each $ as $$.
ADMIN_PASSWORD_HASH=$$2b$$12$$...

# =============================================================================
# Database Credentials (PostgreSQL)
# =============================================================================
# Complete database URL. Overrides config.toml defaults.
# Format: postgresql+psycopg2://user:password@host:port/database
DATABASE_URL=postgresql+psycopg2://app:app@localhost:5432/app

# =============================================================================
# AI Model API Keys
# =============================================================================
# Each provider declared in config.toml's [providers] block reads its key from
# the env var named by that provider's api_key_env field. Add a line below
# for each provider you actually call. Unset providers are fine until first use.

OPENAI_API_KEY=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# =============================================================================
# S3-compatible Backup Storage (required by backup service)
# =============================================================================
# S3 endpoint URL. Examples:
#   AWS S3:       https://s3.amazonaws.com
#   Backblaze B2: https://s3.us-east-005.backblazeb2.com
#   MinIO:        http://minio:9000
#   Alibaba OSS:  https://oss-<region>.aliyuncs.com
#   Tencent COS:  https://cos.<region>.myqcloud.com
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=app-backups
S3_PREFIX=app-backups
# Addressing style: path (MinIO, default), virtual (Alibaba OSS / Tencent COS), auto (AWS S3).
# Picking the wrong value typically returns 403 SecondLevelDomainForbidden or similar.
S3_ADDRESSING_STYLE=path
BACKUP_TIME=18:00
FULL_BACKUP_DAY=6
RETENTION_DAYS=30

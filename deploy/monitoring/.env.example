# =============================================================================
# Monitoring Stack Environment Template
# =============================================================================
# Copy this file to .env and fill in your actual values.

# Public domain used for Grafana Traefik routing.
# Example: example.com (Grafana will be available at grafana.example.com)
DOMAIN=

# Name of the external Docker network where host-level Traefik is running.
TRAEFIK_NETWORK=traefik

# Grafana root URL, used for callbacks and external links.
GRAFANA_ROOT_URL=https://grafana.${DOMAIN}

# Grafana admin password. The default is intentionally insecure; change it.
GF_SECURITY_ADMIN_PASSWORD=admin

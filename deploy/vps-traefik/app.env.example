# /opt/apps/zata-ops/app.env
# Runtime configuration and secrets. This file exists only on the server.
# Never commit a filled copy.

# PostgreSQL connection string.
# Format: postgresql+psycopg2://user:password@host:port/database
DATABASE_URL=

# JWT signing secret. bootstrap.sh fills this when creating app.env.
# Manual generation:
#   openssl rand -hex 32
API_SECRET_KEY=

# Admin login identifier and bcrypt password hash.
# Generate a hash with:
#   python -c 'import bcrypt; print(bcrypt.hashpw(b"change-me", bcrypt.gensalt()).decode())'
ADMIN_IDENTIFIER=admin
ADMIN_PASSWORD_HASH=

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# AI Model API keys. config.toml's [providers] block declares which env var
# each provider reads; add a line for each provider you actually call.
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# S3-compatible backup storage. Required only when the backup profile is used.
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=app-backups
S3_PREFIX=app-backups
S3_ADDRESSING_STYLE=path
BACKUP_TIME=18:00
FULL_BACKUP_DAY=6
RETENTION_DAYS=30

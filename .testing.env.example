# =============================================================================
# Local Testing Middleware — Environment Template
# =============================================================================
# Copy to .testing.env and `docker compose --env-file .testing.env -f
# docker-compose.testing.yml up -d`. Secrets here are intentionally plaintext
# (MinIO/Postgres passwords match docker-compose.testing.yml). NEVER reuse
# these credentials anywhere outside the local testing stack.
#
# Pair with: docker-compose.testing.yml
# Usage:
#   cp .testing.env.example .testing.env
#   docker compose --env-file .testing.env -f docker-compose.testing.yml up -d
# =============================================================================


# =============================================================================
# PostgreSQL (service: postgres)
# =============================================================================
# postgresql+psycopg2://<POSTGRES_USER>:<POSTGRES_PASSWORD>@localhost:5432/<POSTGRES_DB>
DATABASE_URL=postgresql+psycopg2://testuser:testpass@localhost:5432/testdb


# =============================================================================
# Redis (service: redis)
# =============================================================================
# redis://:<requirepass>@localhost:6379/0
REDIS_URL=redis://:redis123@localhost:6379/0


# =============================================================================
# MinIO — S3-compatible Storage (service: minio)
# =============================================================================
# Console:    http://localhost:9001  (minioadmin / minioadmin)
# API:        http://localhost:9000
# Bucket 'app-backups' must be created manually via the console before use.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=app-backups
S3_PREFIX=app-backups
S3_ADDRESSING_STYLE=path


# =============================================================================
# Qdrant — Vector Database (service: qdrant)
# =============================================================================
QDRANT_URL=http://localhost:6333


# =============================================================================
# RAGflow — RAG Pipeline (service: ragflow)
# =============================================================================
# REST API:  http://localhost:9380
# API Key:   must match the RAGFLOW_API_KEY in docker-compose.testing.yml
RAGFLOW_BASE_URL=http://localhost:9380
RAGFLOW_API_KEY=test-ragflow-key
